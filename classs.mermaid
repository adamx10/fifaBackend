
classDiagram
class Arbitre {
  +int id
  +string nom
  +string prenom
  +string nationalite
  +string confederation
  +string categorie
  +int experience
  +string statut
  +getNomComplet() string
  +estDisponible() bool
  +changerStatut(statut) void
  +listerAffectations() Affectation[]
}

class Match {
  +int id
  +string equipeDomicile
  +string equipeExterieur
  +string stade
  +string villeHote
  +date dateMatch
  +string phase
  +getResume() string
  +listerArbitres() Arbitre[]
  +affecterArbitre(arbitre, role) Affectation
  +estComplet() bool
}

class Affectation {
  +int id
  +int arbitreId
  +int matchId
  +string role
  +getArbitre() Arbitre
  +getMatch() Match
  +modifierRole(role) void
  +annuler() void
}

Arbitre "1" --> "0..*" Affectation : possede
Match "1" --> "0..*" Affectation : contient`


